# LLM Wiki Docker环境配置
# 复制此文件为 .env 并修改相应配置

# 服务器配置
PORT=3001
NODE_ENV=production

# Wiki数据目录配置
# 在Docker容器中默认为 /app/wiki-data
# 可以通过docker-compose的卷挂载覆盖
WIKI_ROOT=/app/wiki-data

# Anthropic API配置
# 必需：API密钥
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：自定义API端点（默认为官方端点）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 可选：模型名称（默认为最新Sonnet模型）
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 可选：OpenAI兼容模式（如果使用OpenAI格式的API）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo-preview

# 可选：其他环境变量
# CLAUDE_CODE_USE_ANTHROPIC=1  # 强制使用Anthropic模式
# CLAUDE_CODE_USE_OPENAI=1     # 强制使用OpenAI模式